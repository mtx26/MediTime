# Google
EXPO_PUBLIC_GOOGLE_TRANSLATE_API_KEY=

# Auth redirect. Leave empty in Expo Go so expo-linking generates exp://.../--/auth/callback.
# Set meditime://auth/callback for a development build or standalone app.
EXPO_PUBLIC_AUTH_REDIRECT_URL=
