{
  "schemaVersion": 2,
  "githubRepo": "https://github.com/mtx26/medic",
  "dockerfileLines": [
    "FROM python:3.10",
    "WORKDIR /app",
    "COPY ./backend/requirements.txt /app/",
    "RUN pip install --no-cache-dir -r requirements.txt",
    "COPY ./backend /app",
    "RUN chmod +x /app/start.sh",
    "EXPOSE 5000",
    "CMD [\"/bin/bash\", \"/app/start.sh\"]"
  ]
}
