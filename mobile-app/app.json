{
  "expo": {
    "name": "MediTime",
    "slug": "meditime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5FC3B4",
      "imageUrl": "./assets/icon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meditime.app",
      "icon": "./assets/icon.png",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#5FC3B4",
        "monochromeImage": "./assets/icon.png"
      },
      "package": "com.meditime.app",
      "icon": "./assets/icon.png"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      "expo-notifications",
      "expo-barcode-scanner"
    ],
    "extra": {
      "eas": {
        "projectId": "meditime-mobile-app"
      }
    }
  }
}
